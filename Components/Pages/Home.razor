@page "/"
@rendermode InteractiveServer
@using TwilightImperiumRoller.Models

<div style="    position: absolute;
    width: 100%; height: 100%">
  <div id="stars"></div>
  <div id="stars2"></div>
  <div id="stars3"></div>
</div>
<div style="position: absolute; width: 100%;">
  <PageTitle>TI roller</PageTitle>


  <RadzenTabs RenderMode="TabRenderMode.Client">
    <Tabs>
      <RadzenTabsItem Text="Dice roller">
        <DiceRoller></DiceRoller>
      </RadzenTabsItem>
      <RadzenTabsItem Text="Gamestate">
        <GameState IsAdmin="@isAdmin"></GameState>
      </RadzenTabsItem>
      <RadzenTabsItem Text="Agendas">
        <Agendas IsAdmin="@isAdmin"></Agendas>
      </RadzenTabsItem>
    </Tabs>
  </RadzenTabs>
</div>
